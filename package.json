{
	"name": "@victor-software-house/pi-multicodex",
	"version": "2.3.1",
	"description": "Codex account rotation extension for pi",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.14",
	"keywords": [
		"pi-package",
		"pi",
		"pi-coding-agent",
		"extension",
		"codex",
		"openai",
		"oauth"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"image": "https://raw.githubusercontent.com/victor-software-house/pi-multicodex/main/assets/multicodex-main.png"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/victor-software-house/pi-multicodex.git"
	},
	"homepage": "https://github.com/victor-software-house/pi-multicodex#readme",
	"bugs": {
		"url": "https://github.com/victor-software-house/pi-multicodex/issues"
	},
	"author": "Victor",
	"files": [
		"abort-utils.ts",
		"account-manager.ts",
		"auth.ts",
		"browser.ts",
		"commands.ts",
		"extension.ts",
		"error-format.ts",
		"hooks.ts",
		"index.ts",
		"multicodex-controller.ts",
		"rotation-settings.ts",
		"report.ts",
		"provider.ts",
		"paths.ts",
		"usage-history.ts",
		"quota.ts",
		"selection.ts",
		"status.ts",
		"storage.ts",
		"stream-wrapper.ts",
		"streams.ts",
		"usage-client.ts",
		"usage.ts",
		"README.md",
		"LICENSE",
		"assets/**",
		"schemas/**"
	],
	"scripts": {
		"lint": "node scripts/oxlint.mjs",
		"lint:fix": "node scripts/oxlint.mjs --fix",
		"test": "vitest run -c vitest.config.ts",
		"tsgo": "tsgo -p tsconfig.json",
		"generate:schema": "bun scripts/generate-schema.ts",
		"context-check": "node scripts/context-check.mjs",
		"check": "bun run lint && bun run tsgo && bun run test",
		"pack:dry": "npm pack --dry-run",
		"release:dry": "bunx semantic-release --dry-run"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"peerDependenciesMeta": {
		"@earendil-works/pi-ai": {
			"optional": true
		},
		"@earendil-works/pi-coding-agent": {
			"optional": true
		},
		"@earendil-works/pi-tui": {
			"optional": true
		}
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.4",
		"@commitlint/config-conventional": "^20.4.4",
		"@earendil-works/pi-ai": "^0.80.6",
		"@earendil-works/pi-coding-agent": "^0.80.6",
		"@earendil-works/pi-tui": "^0.80.6",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260314.1",
		"conventional-changelog-conventionalcommits": "^9.3.0",
		"oxlint": "1.73.0",
		"semantic-release": "^25.0.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0"
	},
	"engines": {
		"node": ">=24.14.0"
	}
}
